<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Obs Bank"
            android:textStyle="bold"
            android:textSize="16sp" />

        <!-- para imprimir el FCM token
        <TextView
            android:id="@+id/tokenText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Cargando token..."
            android:textSize="12sp"
            android:textIsSelectable="true"
            android:padding="8dp" />
        -->
        <Button
            android:id="@+id/btnCriticalSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Subscribe Critical" />

        <Button
            android:id="@+id/btnCriticalUnsub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unsubscribe Critical" />

        <Button
            android:id="@+id/btnWarningSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Subscribe Warning" />

        <Button
            android:id="@+id/btnWarningUnsub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unsubscribe Warning" />

        <Button
            android:id="@+id/btnInfoSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Subscribe Info" />

        <Button
            android:id="@+id/btnInfoUnsub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unsubscribe Info" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Estado"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Sin eventos todavía"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="Historial de Alertas"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#333333" />
            
        </LinearLayout>
    </ScrollView>

    <!-- RecyclerView para la lista de tarjetas ocupando el resto de la pantalla -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAlerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>