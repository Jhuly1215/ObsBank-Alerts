<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trazabilidad"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rastreo de transacciones y operaciones"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/circle_bg_dark"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/brand_orange"
                android:layout_marginEnd="8dp"/>
                
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Buscar ID Transacción o Cuenta"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:text="TRX-2026040100234"/>
        </LinearLayout>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rastrear Transacción"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/rounded_button_orange"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card_surface"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_stroke_color">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transacción Encontrada" android:textStyle="bold" android:textColor="@color/text_primary" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Nueva Búsqueda" android:textColor="@color/brand_orange" android:textStyle="bold"/>
                </RelativeLayout>
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="ID Transacción:" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRX-2026040100234" android:textColor="@color/text_primary"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Estado:" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Error Timeout" android:textColor="@color/status_critical" android:textStyle="bold"/>
                </LinearLayout>
                
                 <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Duración Total:" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3.891 segundos" android:textColor="@color/text_primary"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Ciclo de Vida -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="80dp"
            app:cardBackgroundColor="@color/bg_card_surface"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_stroke_color">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ciclo de Vida"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp" />

                <!-- Timeline Nodes Estáticos para la demo -->
                <include layout="@layout/item_timeline" android:id="@+id/node1"/>
                 <include layout="@layout/item_timeline" android:id="@+id/node2"/>
                <include layout="@layout/item_timeline_error" android:id="@+id/node3"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
